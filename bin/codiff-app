#!/bin/sh
set -eu

source_path="$0"

while [ -L "$source_path" ]; do
  source_dir="$(CDPATH= cd -P "$(dirname "$source_path")" >/dev/null 2>&1 && pwd)"
  linked_path="$(readlink "$source_path")"

  case "$linked_path" in
    /*) source_path="$linked_path" ;;
    *) source_path="$source_dir/$linked_path" ;;
  esac
done

script_dir="$(CDPATH= cd -P "$(dirname "$source_path")" >/dev/null 2>&1 && pwd)"
app_path="$(CDPATH= cd -P "$script_dir/../../../.." >/dev/null 2>&1 && pwd)"

codiff_version() {
  sed -n 's/^  "version": "\([^"]*\)".*/\1/p' "$script_dir/../package.json"
}

show_help() {
  version="$(codiff_version)"
  cat <<EOF
codiff v${version} — A fast local diff viewer.

Usage: codiff [options] [<ref> | <pr> | <url>] [path]

Options:
  --commit <ref>        Review a specific commit.
  --help, -h            Show this help message and exit.
  --version, -v         Show version number and exit.
  --walkthrough, -w     Start with an LLM-generated review walkthrough.

Examples:
  codiff                Review staged and unstaged changes.
  codiff /path/to/repo  Review changes in a specific repository.
  codiff a1b2c3d        Review a specific commit.
  codiff '#75'          Review pull request #75.
  codiff pr 75          Review pull request #75 (alternate syntax).
  codiff -w             Start with an LLM walkthrough.
  codiff -w a1b2c3d     Walkthrough a specific commit.
EOF
}

repository_path=""
commit_ref=""
pull_request_source=""
expect_commit_ref=0
expect_pull_request_number=0
walkthrough=0

is_commit_ref_arg() {
  ref_arg="$1"

  if [ -e "$ref_arg" ]; then
    return 1
  fi

  if printf '%s' "$ref_arg" | grep -Eq '^[0-9a-fA-F]{4,64}$'; then
    return 0
  fi

  if printf '%s' "$ref_arg" | grep -Eq '^(@|HEAD)(([~^][0-9]*)|(\^\{[^}]+\})|(@\{[^}]+\}))*$'; then
    return 0
  fi

  if printf '%s' "$ref_arg" | grep -Eq '(\^|~|@\{[^}]+\})'; then
    return 0
  fi

  return 1
}

for arg in "$@"; do
  if [ "$expect_commit_ref" -eq 1 ]; then
    commit_ref="$arg"
    expect_commit_ref=0
    continue
  fi

  if [ "$expect_pull_request_number" -eq 1 ]; then
    if printf '%s' "$arg" | grep -Eq '^[1-9][0-9]*$'; then
      pull_request_source="#$arg"
      expect_pull_request_number=0
      continue
    fi
    expect_pull_request_number=0
  fi

  case "$arg" in
    --help|-h)
      show_help
      exit 0
      ;;
    --version|-v)
      printf 'codiff v%s\n' "$(codiff_version)"
      exit 0
      ;;
    --walkthrough|-w)
      walkthrough=1
      ;;
    --commit)
      expect_commit_ref=1
      ;;
    --commit=*)
      commit_ref="${arg#--commit=}"
      ;;
    -*)
      ;;
    *)
      if [ -z "$pull_request_source" ] && printf '%s' "$arg" | grep -Eiq '^(pr|pull-request)$'; then
        expect_pull_request_number=1
      elif [ -z "$pull_request_source" ] && printf '%s' "$arg" | grep -Eq '^#[1-9][0-9]*$'; then
        pull_request_source="$arg"
      elif [ -z "$pull_request_source" ] && printf '%s' "$arg" | grep -Eq '^https://github\.com/[^/]+/[^/]+/pull/[0-9]+/?$'; then
        pull_request_source="$arg"
      elif [ -z "$commit_ref" ] && is_commit_ref_arg "$arg"; then
        commit_ref="$arg"
      elif [ -z "$repository_path" ]; then
        repository_path="$arg"
      fi
      ;;
  esac
done

repository_path="${repository_path:-$PWD}"

case "$repository_path" in
  /*) ;;
  *) repository_path="$PWD/$repository_path" ;;
esac

if [ -n "$pull_request_source" ] && [ "$walkthrough" -eq 1 ]; then
  open -n "$app_path" --args --walkthrough "$pull_request_source" "$repository_path"
elif [ -n "$pull_request_source" ]; then
  open -n "$app_path" --args "$pull_request_source" "$repository_path"
elif [ -n "$commit_ref" ] && [ "$walkthrough" -eq 1 ]; then
  open -n "$app_path" --args --walkthrough --commit "$commit_ref" "$repository_path"
elif [ -n "$commit_ref" ]; then
  open -n "$app_path" --args --commit "$commit_ref" "$repository_path"
elif [ "$walkthrough" -eq 1 ]; then
  open -n "$app_path" --args --walkthrough "$repository_path"
else
  open -n "$app_path" --args "$repository_path"
fi
